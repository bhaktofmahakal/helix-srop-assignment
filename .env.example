# ── LLM Provider ────────────────────────────────────────────────────────────
# LLM_PROVIDER: auto | gemini | groq
# - auto: prefer Gemini if GOOGLE_API_KEY is set, else Groq
# - gemini: use Google ADK with Gemini (requires GOOGLE_API_KEY)
# - groq: use Groq SDK with Llama (requires GROQ_API_KEY)
LLM_PROVIDER=auto

# Gemini path (google-adk with gemini-2.0-flash)
GOOGLE_API_KEY=
# Groq path (llama-3.3-70b-versatile fallback when no GOOGLE_API_KEY)
GROQ_API_KEY=

# Model overrides (optional)
ADK_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./helix_srop.db
# Postgres (for Postgres-compatible schema):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/helix_srop

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
# LANCEDB_PATH=./lancedb
# PINECONE_API_KEY=...
# PINECONE_INDEX=helix-docs

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-prod     # used for JWT signing (extension E2)

# ── Model Selection ───────────────────────────────────────────────────────────
# Which model the ADK agents use. Gemini Flash is fast + cheap for dev.
ADK_MODEL=gemini-2.0-flash       # or: gemini-1.5-pro, gpt-4o, claude-3-5-sonnet

# ── Agent Timeouts ────────────────────────────────────────────────────────────
LLM_TIMEOUT_SECONDS=30
TOOL_TIMEOUT_SECONDS=10
